class Solution:
    def subsetSums(self, nums):
        ans = []

        def generate(idx, curr_sum):
            if idx == len(nums):
                ans.append(curr_sum)
                return

            # Pick current element
            generate(idx + 1, curr_sum + nums[idx])

            # Don't pick current element
            generate(idx + 1, curr_sum)

        generate(0, 0)
        return ans
