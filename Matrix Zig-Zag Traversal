n, m = map(int, input().split())

mat = []
for _ in range(n):
    mat.append(list(map(int, input().split())))

for i in range(n):
    if i % 2 == 0:           # left to right
        for j in range(m):
            print(mat[i][j], end=" ")
    else:                    # right to left
        for j in range(m-1, -1, -1):
            print(mat[i][j], end=" ")
