class Solution:
    def largeOddNum(self, s: str) -> str:

        # Find rightmost odd digit
        ind = -1

        for i in range(len(s) - 1, -1, -1):
            if int(s[i]) % 2 == 1:
                ind = i
                break

        # No odd digit found
        if ind == -1:
            return ""

        # Remove leading zeros
        start = 0
        while start <= ind and s[start] == '0':
            start += 1

        return s[start:ind + 1]
        
